{
  "name": "@snowyowl/components",
  "version": "0.1.0",
  "description": "SnowyOwl web components — framework-agnostic, built with Lit",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./components/*": "./dist/components/*/index.js"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "lit": "^3.1.0",
    "@snowyowl/tokens": "workspace:*",
    "@snowyowl/icons": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "customElements": "custom-elements.json"
}
