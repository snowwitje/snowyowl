{
  "name": "@snowyowl/tokens",
  "version": "0.1.2",
  "description": "SnowyOwl design tokens — primitives, semantic, and component-level CSS custom properties",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/snowwitje/snowyowl.git",
    "directory": "packages/tokens"
  },
  "homepage": "https://snowwitje.github.io/snowyowl/docs/",
  "keywords": [
    "design-tokens",
    "css-custom-properties",
    "design-system",
    "theming",
    "snowyowl",
    "style-dictionary",
    "tokens-studio"
  ],
  "exports": {
    ".": {
      "import": "./dist/js/light.mjs",
      "require": "./dist/js/light.cjs"
    },
    "./css/*": "./dist/css/*.css",
    "./js/*": {
      "import": "./dist/js/*.mjs",
      "require": "./dist/js/*.cjs"
    },
    "./json/*": "./dist/json/*.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@tokens-studio/sd-transforms": "^2.0.3",
    "style-dictionary": "^4.1.0"
  }
}
