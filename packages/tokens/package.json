{
  "name": "@snowyowl/tokens",
  "version": "0.1.0",
  "description": "SnowyOwl design tokens — primitives, semantic, and component-level",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css": "./dist/tokens.css",
    "./json": "./dist/tokens.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "style-dictionary": "^4.1.0"
  }
}
