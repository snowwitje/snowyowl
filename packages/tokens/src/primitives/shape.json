{
  "radius": {
    "none":  { "$value": "0px",     "$type": "borderRadius" },
    "xs":    { "$value": "2px",     "$type": "borderRadius" },
    "sm":    { "$value": "4px",     "$type": "borderRadius" },
    "md":    { "$value": "6px",     "$type": "borderRadius" },
    "lg":    { "$value": "8px",     "$type": "borderRadius" },
    "xl":    { "$value": "12px",    "$type": "borderRadius" },
    "2xl":   { "$value": "16px",    "$type": "borderRadius" },
    "3xl":   { "$value": "24px",    "$type": "borderRadius" },
    "full":  { "$value": "9999px",  "$type": "borderRadius", "$description": "Pills, avatars, badges" }
  },

  "shadow": {
    "none": {
      "$value": "none",
      "$type": "shadow"
    },
    "xs": {
      "$value": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "$type": "shadow",
      "$description": "Subtle lift — inputs, chips"
    },
    "sm": {
      "$value": "0 1px 3px 0 rgba(0, 0, 0, 0.08), 0 1px 2px -1px rgba(0, 0, 0, 0.05)",
      "$type": "shadow",
      "$description": "Default component elevation"
    },
    "md": {
      "$value": "0 4px 6px -1px rgba(0, 0, 0, 0.08), 0 2px 4px -2px rgba(0, 0, 0, 0.05)",
      "$type": "shadow",
      "$description": "Cards, dropdowns"
    },
    "lg": {
      "$value": "0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -4px rgba(0, 0, 0, 0.05)",
      "$type": "shadow",
      "$description": "Floating panels, popovers"
    },
    "xl": {
      "$value": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.05)",
      "$type": "shadow",
      "$description": "Modals, dialogs"
    },
    "2xl": {
      "$value": "0 25px 50px -12px rgba(0, 0, 0, 0.18)",
      "$type": "shadow",
      "$description": "Drawers, full-screen overlays"
    },
    "inner": {
      "$value": "inset 0 2px 4px 0 rgba(0, 0, 0, 0.05)",
      "$type": "shadow",
      "$description": "Inset fields, pressed states"
    }
  },

  "border": {
    "width": {
      "none":   { "$value": "0px", "$type": "borderWidth" },
      "thin":   { "$value": "1px", "$type": "borderWidth" },
      "medium": { "$value": "2px", "$type": "borderWidth" },
      "thick":  { "$value": "4px", "$type": "borderWidth" }
    }
  },

  "opacity": {
    "0":    { "$value": "0",    "$type": "opacity" },
    "10":   { "$value": "0.10", "$type": "opacity" },
    "20":   { "$value": "0.20", "$type": "opacity" },
    "40":   { "$value": "0.40", "$type": "opacity" },
    "50":   { "$value": "0.50", "$type": "opacity" },
    "60":   { "$value": "0.60", "$type": "opacity" },
    "70":   { "$value": "0.70", "$type": "opacity" },
    "80":   { "$value": "0.80", "$type": "opacity" },
    "90":   { "$value": "0.90", "$type": "opacity" },
    "100":  { "$value": "1",    "$type": "opacity" }
  },

  "duration": {
    "instant":  { "$value": "0ms",   "$type": "duration" },
    "fast":     { "$value": "100ms", "$type": "duration", "$description": "Micro-interactions" },
    "normal":   { "$value": "200ms", "$type": "duration", "$description": "Standard transitions" },
    "slow":     { "$value": "300ms", "$type": "duration", "$description": "Panels, modals" },
    "slower":   { "$value": "500ms", "$type": "duration" },
    "lazy":     { "$value": "700ms", "$type": "duration", "$description": "Page-level animations" }
  },

  "easing": {
    "default":    { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier", "$description": "General purpose" },
    "in":         { "$value": "cubic-bezier(0.4, 0, 1, 1)",   "$type": "cubicBezier", "$description": "Exits" },
    "out":        { "$value": "cubic-bezier(0, 0, 0.2, 1)",   "$type": "cubicBezier", "$description": "Entrances" },
    "in-out":     { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
    "spring":     { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier", "$description": "Springy, playful" },
    "linear":     { "$value": "linear", "$type": "cubicBezier" }
  }
}
